<div class="row mt-3">
  <div class="col-sm mt-3 mt-md-0">
      <a href="https://www.tsinghua.edu.cn/" title="THU logo"><img src="./assets/THU.jpg"></a>
  </div>
  <div class="col-sm mt-3 mt-md-0">
      <a href="https://www.bupt.edu.cn/" title="BUPT logo"><img src="./assets/BUPT.jpg"></a>
  </div>
  <div class="col-sm mt-3 mt-md-0">
    <script type="text/javascript" src="//rf.revolvermaps.com/0/0/6.js?i=5p1vgpku629&amp;m=7&amp;c=e63100&amp;cr1=ffffff&amp;f=arial&amp;l=0&amp;bv=90&amp;lx=-420&amp;ly=420&amp;hi=20&amp;he=7&amp;hc=a8ddff&amp;rs=80" async="async"></script>
